{%- comment -%}
Icon Component
Usage: {% render "_icon", name: "arrow", iconSize: "24" %}

Parameters:
- name: アイコン名（必須）
- iconSize: サイズ（デフォルト: 24）※ Liquid 予約語 size との衝突を避けるため iconSize
- class: 追加のCSSクラス
- label: アクセシビリティ用のラベル
{%- endcomment -%}

{%- assign icon_size = iconSize -%}
{%- unless icon_size -%}
{%- assign icon_size = "24" -%}
{%- endunless -%}
{%- assign icon_class = class -%}
{%- unless icon_class -%}
{%- assign icon_class = "" -%}
{%- endunless -%}

<svg class="icon -{{ name }} {{ icon_class }}" width="{{ icon_size }}" height="{{ icon_size }}" {%- if label %} aria-label="{{ label }}" {% else %} aria-hidden="true" {% endif -%}>
	<use href="/assets/icons/sprite.svg#icon-{{ name }}"></use>
</svg>