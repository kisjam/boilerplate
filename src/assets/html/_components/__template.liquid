{% comment %}
  Component: c-card
  カード型のリンクコンポーネント。サムネイル・タイトル・日付などを表示します。

  Parameters:
    class    {String}  追加CSSクラス (optional)
    url      {String}  リンクURL (default: '#')
    image    {String}  サムネイル画像パス (default: '/assets/images/dummy/cat.webp')
    alt      {String}  画像のalt属性 (default: '')
    width    {Number}  画像の幅px (default: 1280)
    height   {Number}  画像の高さpx (default: 896)
    show_new {Boolean} NEWバッジの表示 (optional)
    rank     {String}  ランク表示テキスト (optional)
    category {String}  カテゴリテキスト (optional)
    title    {String}  カードタイトル (default: 'タイトルが入ります')
    date     {String}  日付テキスト (default: '2025.00.00')

  Usage:
    {% render '_template',
      url: '/news/1',
      image: '/assets/images/news/1.webp',
      title: '記事タイトル',
      date: '2025.01.01',
      category: 'お知らせ'
    %}
{% endcomment %}

{% assign _image = image | default: '/assets/images/dummy/cat.webp' %}
{% assign _alt = alt | default: '' %}
{% assign _width = width | default: 1280 %}
{% assign _height = height | default: 896 %}

<div class="c-card{% if class %} {{ class }}{% endif %}">
	<a href="{{ url | default: '#' }}" class="c-card__link">
		<div class="c-card__header">
			<div class="c-card__thumb">
				<img src="{{ _image }}" alt="{{ _alt }}" width="{{ _width }}" height="{{ _height }}">
			</div>
			{% if show_new %}
			<div class="c-card__new">NEW</div>
			{% endif %}
			{% if rank %}
			<div class="c-card__rank">{{ rank }}</div>
			{% endif %}
		</div>
		<div class="c-card__body">
			{% if category %}
			<div class="c-card__category">
				<div class="c-card__category-item">{{ category }}</div>
			</div>
			{% endif %}
			<h2 class="c-card__title">{{ title | default: 'タイトルが入ります' }}</h2>
			<p class="c-card__date">{{ date | default: '2025.00.00' }}</p>
		</div>
	</a>
</div>
