{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useTemplate": "error"
			},
			"correctness": {
				"noUnusedVariables": "error"
			},
			"suspicious": {
				"noExplicitAny": "warn"
			},
			"complexity": {
				"noForEach": "off"
			}
		},
		"includes": ["**", "!**/dist", "!**/node_modules", "!**/*.min.js"]
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100,
		"lineEnding": "lf",
		"includes": ["**", "!**/dist", "!**/node_modules"]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"jsxQuoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all",
			"arrowParentheses": "always"
		}
	},
	"files": {
		"includes": ["**", "!**/dist", "!**/node_modules", "!**/.git", "!**/.claude", "!**/*.log"]
	}
}
